{
  "name": "fake-recaptcha",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "恶搞版的 reCAPTCHA 验证码，无论怎么选都会失败",
  "homepage": "https://Steven-Qiang.github.io/fake-recaptcha/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Steven-Qiang/fake-recaptcha.git"
  },
  "keywords": [
    "vue",
    "recaptcha",
    "fake",
    "captcha",
    "vue3",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fake-recaptcha.es.js",
      "require": "./dist/fake-recaptcha.cjs.js",
      "default": "./dist/fake-recaptcha.es.js"
    }
  },
  "main": "./dist/fake-recaptcha.umd.js",
  "module": "./dist/fake-recaptcha.es.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vue-tsc -b && vite build --mode lib",
    "lint": "eslint . --fix",
    "prettier": "prettier --write \"**/*.{vue,js,ts,json,html,css,scss,md,mjs}\""
  },
  "peerDependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint-plugin-format": "^2.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vue-tsc": "^3.2.6"
  }
}
